// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Plan {
  FREE
  TRIAL
  PRO
}

enum MemberRole {
  ADMIN
  MEMBRO
}

model User {
  id                     String    @id @default(uuid())
  name                   String?
  email                  String    @unique
  emailVerified          DateTime?
  image                  String?
  plan                   Plan      @default(FREE)
  trialEndsAt            DateTime?
  stripeCustomerId       String?   @unique
  stripePriceId          String?
  stripeSubscriptionId   String?   @unique
  stripeCurrentPeriodEnd DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]
  espacos   Espaco[]   @relation("EspacoCriador")
  membros   Membro[]
  memorias  Memoria[]
  convites  Convite[]  @relation("ConviteCriador")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Espaco {
  id                  String    @id @default(uuid())
  nome                String
  criadoPor           String
  codigoConvite       String    @unique @default(uuid())
  armazenamentoUsadoMb Float    @default(0)
  arquivadoEm         DateTime?
  criadoEm            DateTime  @default(now())
  atualizadoEm        DateTime  @updatedAt

  criador  User      @relation("EspacoCriador", fields: [criadoPor], references: [id], onDelete: Cascade)
  membros  Membro[]
  memorias Memoria[]
  convites Convite[]
}

model Memoria {
  id                String    @id @default(uuid())
  espacoId          String
  autorId           String
  titulo            String
  conteudo          String?   @db.Text
  imagemUrl         String?
  imagemTamanhoKb   Float?
  anoAcontecimento  Int
  criadoEm          DateTime  @default(now())
  atualizadoEm      DateTime  @updatedAt
  deletadoEm        DateTime?

  espaco Espaco @relation(fields: [espacoId], references: [id], onDelete: Cascade)
  autor  User   @relation(fields: [autorId], references: [id], onDelete: Cascade)

  @@index([espacoId, anoAcontecimento])
  @@index([espacoId, deletadoEm])
}

model Membro {
  id           String     @id @default(uuid())
  espacoId     String
  userId       String
  papel        MemberRole @default(MEMBRO)
  convidadoPor String?
  aceitoEm     DateTime   @default(now())

  espaco Espaco @relation(fields: [espacoId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([espacoId, userId])
}

model Convite {
  id          String    @id @default(uuid())
  espacoId    String
  criadoPor   String
  codigo      String    @unique @default(uuid())
  usadoPor    String?
  usadoEm     DateTime?
  expiraEm    DateTime

  espaco  Espaco @relation(fields: [espacoId], references: [id], onDelete: Cascade)
  criador User   @relation("ConviteCriador", fields: [criadoPor], references: [id], onDelete: Cascade)
}
